# Configuracion por empresa (white-label). Copiar a .env (o variables de entorno
# del despliegue) y ajustar. El MISMO codigo sirve para cualquier empresa.
PORT=3000

# Zona horaria de la empresa (afecta al agrupado por dias y a las horas mostradas)
TZ=Atlantic/Canary

# ---- Identidad de la empresa (aparece en cabecera e informes PDF) ----
EMPRESA_NOMBRE=Nombre de la empresa
EMPRESA_CIF=
EMPRESA_DIR=

# Logo de la empresa: NO va en el codigo. Coloca el archivo en la carpeta de
# datos como  data/logo.png  (o .svg/.jpg). Si no hay, se usa un logo neutro.

# Reforzar bloqueo por IP (solo si la IP publica del local es fija)
ENFORCE_DEVICE_IP=false
